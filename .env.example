# ==============================================================================
# KAIROSYN-1 Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# ==============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Hugging Face token (required for Gemma 4 access)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── Optional: Model ───────────────────────────────────────────────────────────

# Path to fine-tuned checkpoint (leave empty to use base Gemma 4)
MODEL_CHECKPOINT=

# Model config (default: E4B dev config)
KAIROSYN_CONFIG=configs/model/kairosyn_e4b.yaml

# ── Optional: Server ──────────────────────────────────────────────────────────

# API server port
PORT=8080

# Uvicorn workers (keep at 1 for GPU — model is not multi-process safe)
WORKERS=1

# Session TTL in seconds (default: 2 hours)
SESSION_TTL=7200

# Maximum concurrent sessions
MAX_SESSIONS=1000

# ── Optional: Monitoring ──────────────────────────────────────────────────────

# Weights & Biases (training tracking)
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=kairosyn-1
WANDB_MODE=online   # online | offline | disabled

# Grafana admin password
GRAFANA_PASS=kairosyn_admin

# ── Optional: Kubernetes Deploy ───────────────────────────────────────────────

# Git SHA for image tagging
GIT_SHA=local

# Semantic version
VERSION=1.0.0

# Build timestamp
BUILD_DATE=2025-04-19T00:00:00Z

# ACME email for TLS cert generation
ACME_EMAIL=research@or4cl3.ai

# ── Optional: GitHub Container Registry ──────────────────────────────────────

# For pushing images to GHCR (set in CI via GITHUB_TOKEN)
GITHUB_TOKEN=your_github_token_here
